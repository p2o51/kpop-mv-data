{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/local/kpop-mv-data/schemas/daily-manifest.schema.json",
  "title": "Daily public dataset manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "date",
    "collector_version",
    "records",
    "sha256",
    "generated_at"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "collector_version": { "type": "string" },
    "records": { "type": "integer", "minimum": 0 },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source": { "type": "string" },
    "object_key": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" }
  }
}
