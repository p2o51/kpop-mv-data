---
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Open K-pop MV public view-count infrastructure. Facts only."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      <nav>
        <a class="brand" href="/">kpop-mv-data</a>
        <div class="links">
          <a href="https://github.com/" rel="noreferrer">GitHub</a>
          <a href="/methodology">Methodology</a>
        </div>
      </nav>
      <main>
        <slot />
      </main>
      <footer>
        <p>
          Public facts layer · MIT · Not affiliated with YouTube, HYBE, SM, JYP,
          or YG.
        </p>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg0: #0f1412;
    --bg1: #17201c;
    --ink: #e8f0ea;
    --muted: #9bb0a3;
    --line: rgba(232, 240, 234, 0.12);
    --accent: #c8f55a;
    --accent-ink: #10160f;
    --card: rgba(255, 255, 255, 0.03);
    --serif: "Instrument Serif", "Times New Roman", serif;
    --sans: "IBM Plex Sans", "Helvetica Neue", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
    background:
      radial-gradient(1200px 600px at 10% -10%, #24352c 0%, transparent 55%),
      radial-gradient(900px 500px at 100% 0%, #1a2a40 0%, transparent 50%),
      var(--bg0);
    color: var(--ink);
    font-family: var(--sans);
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  .shell {
    width: min(1080px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 1.25rem 0 4rem;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .brand {
    font-family: var(--serif);
    font-size: 1.35rem;
    color: var(--ink);
    letter-spacing: 0.01em;
  }

  .links {
    display: flex;
    gap: 1rem;
    font-size: 0.92rem;
  }

  .hero {
    padding: 3.5rem 0 2rem;
  }

  .eyebrow {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  h1 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(2.8rem, 8vw, 5rem);
    line-height: 0.95;
    margin: 0 0 1rem;
  }

  .lede {
    max-width: 38rem;
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin: 0 0 3rem;
  }

  .stats div {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1rem 1.1rem;
  }

  .stats strong {
    display: block;
    font-family: var(--serif);
    font-size: 2rem;
    line-height: 1;
  }

  .stats span {
    color: var(--muted);
    font-size: 0.85rem;
  }

  section {
    margin-bottom: 3rem;
  }

  h2 {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 1.8rem;
    margin: 0 0 1rem;
  }

  .plain {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.92rem;
  }

  th,
  td {
    text-align: left;
    padding: 0.7rem 0.4rem;
    border-bottom: 1px solid var(--line);
  }

  th {
    color: var(--muted);
    font-weight: 500;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .act {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.9rem 1rem;
  }

  .act h3 {
    margin: 0;
    font-size: 1rem;
  }

  .act p {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 0.85rem;
  }

  .act .meta {
    margin-top: 0.55rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .note {
    border-top: 1px solid var(--line);
    padding-top: 1.5rem;
  }

  .note p {
    color: var(--muted);
    max-width: 40rem;
    line-height: 1.6;
  }

  footer {
    border-top: 1px solid var(--line);
    padding-top: 1.25rem;
    color: var(--muted);
    font-size: 0.82rem;
  }

  code {
    font-size: 0.9em;
    color: var(--accent);
  }

  @media (max-width: 720px) {
    .stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
